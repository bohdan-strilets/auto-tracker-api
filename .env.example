# App
PORT=3000
NODE_ENV=development | production | test

# Database
DATABASE_URL=postgresql://user:password@localhost:port/db-name

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
ARGON2_PEPPER=your-pepper-value

# Authentication
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=15

# Email Tokens
TOKEN_EMAIL_VERIFY_EXPIRES_MINUTES=60
TOKEN_EMAIL_CHANGE_EXPIRES_MINUTES=60
TOKEN_PASSWORD_RESET_EXPIRES_MINUTES=15

# JWT
JWT_ACCESS_SECRET=access-secret-key
JWT_REFRESH_SECRET=refresh-secret-key
JWT_ACCESS_EXPIRES_MINUTES=10
JWT_REFRESH_EXPIRES_DAYS=7

# Resend
RESEND_API_KEY=resend-api-key
MAIL_FROM_EMAIL=noreply@yourdomain.com
APP_URL=https://yourdomain.com

# Throttling
THROTTLE_DEFAULT_TTL=60000
THROTTLE_DEFAULT_LIMIT=60
THROTTLE_AUTH_TTL=60000
THROTTLE_AUTH_LIMIT=5